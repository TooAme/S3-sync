# Required
SRC_BUCKET=prod-bucket-name
DST_BUCKET=test-bucket-name
SRC_REGION=ap-northeast-1
DST_REGION=ap-northeast-1
# For MinIO or other S3-compatible storage, set endpoint like:
# http://minio.example.com:9000
SRC_S3_ENDPOINT=
DST_S3_ENDPOINT=
SRC_S3_ADDRESSING_STYLE=auto
DST_S3_ADDRESSING_STYLE=auto
PREFIX=
EXACT_KEY=

# Source credential options (priority: AK/SK > profile > default chain)
SRC_AWS_ACCESS_KEY_ID=your_prod_access_key
SRC_AWS_SECRET_ACCESS_KEY=your_prod_secret_key
SRC_AWS_SESSION_TOKEN=
SRC_AWS_PROFILE=

# Destination credential options (priority: AK/SK > profile > default chain)
# Scenario A (you now): fill DST_AWS_ACCESS_KEY_ID / DST_AWS_SECRET_ACCESS_KEY
# Scenario B (run in test env): keep these empty, use test env default role/metadata
DST_AWS_ACCESS_KEY_ID=
DST_AWS_SECRET_ACCESS_KEY=
DST_AWS_SESSION_TOKEN=
DST_AWS_PROFILE=

# Performance tuning
WORKERS=8
MULTIPART_THRESHOLD_MB=64
MULTIPART_CHUNK_MB=16
PROGRESS_EVERY=200
FORCE_OVERWRITE=true

# Logging / diagnostics
LOG_LEVEL=INFO
LOG_FILE=
FULL_RESPONSE=false
DEBUG_BOTOCORE=false
TRACEBACK_ON_ERROR=false
